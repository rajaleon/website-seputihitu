# ============================================================
# Environment Variables untuk deploy di Vercel
# ============================================================

# Frontend (public)
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxx
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false

# Server-side (untuk API routes)
DATABASE_URL=postgresql://postgres.xxxxx:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
JWT_SECRET=your_random_secret_min_64_chars
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxx
MIDTRANS_IS_PRODUCTION=false
BITESHIP_API_KEY=biteship_test.xxxxxxxx
BITESHIP_ORIGIN_POSTAL_CODE=10110
