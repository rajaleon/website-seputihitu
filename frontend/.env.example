# ============================================================
# Frontend Environment Variables — Seputihitu E-Commerce
# Salin file ini ke .env.local lalu isi nilainya
# JANGAN commit file .env.local ke git!
# ============================================================

# ── API Backend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# ── Midtrans (Client Key — aman untuk di-expose ke frontend) ─
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false
